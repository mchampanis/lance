BOT_TOKEN=your-bot-token-here
GUILD_IDS=123456789,987654321

# Bot identity
BOT_NAME=Lance

# Database
DB_PATH=lance.db

# Stream announcements
STREAM_CHANNEL_NAME=lounge
STREAM_ROLE_NAME=LFG Stream

# Timezone helper page (linked from /lance settings)
TIMEZONE_HELPER_URL=https://guides.firstwavesurvivors.com/tools/timezone

# Emoji that triggers time conversion (Unicode character, default: clock face)
# TIME_REACT_EMOJI=

# Hours before giveaway items auto-expire (default 72)
# GIVEAWAY_EXPIRY_HOURS=72

# Healthchecks.io ping URL (optional)
# HEALTHCHECK_URL=https://hc-ping.com/your-uuid
