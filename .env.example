BOT_TOKEN=your-bot-token-here
GUILD_IDS=123456789,987654321

# Bot identity
BOT_NAME=Lance

# Database
DB_PATH=lance.db

# Stream announcements
STREAM_CHANNEL_NAME=lounge
STREAM_ROLE_NAME=LFG Stream

# Timezone helper page (linked from /lance settings)
TIMEZONE_HELPER_URL=https://zones.arilyn.cc/

# Emoji that triggers time conversion (Unicode character, default: clock face)
# TIME_REACT_EMOJI=

# Hours before giveaway items auto-expire (default 120 = 5 days)
# GIVEAWAY_EXPIRY_HOURS=120

# Milestone roles: "count:Role Name,..." -- roles must exist in the guild.
# Bot awards highest earned, removes lower ones.
# GIVEAWAY_MILESTONES=1:Freebie Giver,5:Freebie Apprentice,10:Freebie Enthusiast,50:Freebie Champion,100:Freebie Master

# Healthchecks.io ping URL (optional)
# HEALTHCHECK_URL=https://hc-ping.com/your-uuid
